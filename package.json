{
  "name": "llms2md",
  "version": "1.0.0",
  "description": "Turn an llms.txt file into a local Markdown docs repository.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PremierStudio/llms2md.git"
  },
  "homepage": "https://github.com/PremierStudio/llms2md#readme",
  "bugs": {
    "url": "https://github.com/PremierStudio/llms2md/issues"
  },
  "type": "module",
  "bin": "./index.js",
  "keywords": [
    "llms-txt",
    "markdown",
    "docs",
    "cli"
  ],
  "files": [
    "index.js",
    "CHANGELOG.md",
    "LICENSE",
    "lib",
    "sources.txt",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "check": "node --check index.js",
    "check:registry": "node scripts/check-registry-safety.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "release": "semantic-release"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "node-fetch": "^3.3.2",
    "p-limit": "^5.0.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.4",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "semantic-release": "^25.0.3",
    "vitest": "^3.2.4"
  }
}
