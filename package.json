{
  "name": "llms2md",
  "version": "1.0.0",
  "description": "Turn an llms.txt file into a local Markdown docs repository.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PremierStudio/llms2md.git"
  },
  "homepage": "https://github.com/PremierStudio/llms2md#readme",
  "bugs": {
    "url": "https://github.com/PremierStudio/llms2md/issues"
  },
  "type": "module",
  "bin": "./index.js",
  "keywords": [
    "llms-txt",
    "markdown",
    "docs",
    "cli"
  ],
  "files": [
    "index.js",
    "lib",
    "sources.txt",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "check": "node --check index.js",
    "check:registry": "node scripts/check-registry-safety.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "node-fetch": "^3.3.2",
    "p-limit": "^5.0.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.2.4"
  }
}
